EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id

EXPO_PUBLIC_CHAPA_SECRET_KEY=your_chapa_secret_key
# Legacy fallback (optional): EXPO_PUBLIC_CHAPA_API_KEY=your_chapa_secret_key
EXPO_PUBLIC_WEBHOOK_URL=https://your-backend.com/api/payments/webhook

# Telegram Login Widget
# 1. Create a bot via @BotFather on Telegram
# 2. Run /setdomain and register your allowed domain (e.g. oauth.telegram.org for testing)
# 3. Paste the numeric bot ID here (NOT the token — the ID only)
EXPO_PUBLIC_TELEGRAM_BOT_ID=your_telegram_bot_id

# Telegram Bot Token — keep this SECRET, never commit it.
# Add it as a Supabase secret: supabase secrets set TELEGRAM_BOT_TOKEN=<token>
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
